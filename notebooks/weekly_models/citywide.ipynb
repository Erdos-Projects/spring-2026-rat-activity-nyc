   "source": [
    "FEATURES = ['apparent_temperature_min_lag30',\n",
    "            'apparent_temperature_min_lag60',\n",
    "            'apparent_temperature_min_lag120',\n",
    "            'apparent_temperature_min_lag365',\n",
    "            'apparent_temperature_min_lag730',\n",
    "            'dayofyear', \n",
    "            #'temperature_2m_max_lag30',\n",
