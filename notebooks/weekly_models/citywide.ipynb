   "cell_type": "code",
   "execution_count": 104,
   "id": "8478e028",
   "metadata": {},
   "outputs": [],
   "source": [
    "tscv = TimeSeriesSplit(gap=0, max_train_size=None, n_splits=26, test_size=14)"
   ]
